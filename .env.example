# DRS Studio reads these in the browser (client-side) for hackathon demo speed.
# Put your NewsData key here:
PUBLIC_NEWSDATA_API_KEY=your_newsdata_io_key

# Put your Gemini key here (works even if you host on GCP):
PUBLIC_GEMINI_API_KEY=your_google_gemini_api_key
PUBLIC_GEMINI_MODEL=gemini-2.5-pro
